# ─── App ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ─── Security ──────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-64+-random-bytes
JWT_ALG=HS256
JWT_TTL_MIN=60
# Master encryption key used to wrap per-user DEKs (envelope encryption).
# In production this MUST come from a real KMS (AWS KMS / GCP KMS / Vault).
# For local dev only, a base64-encoded 32-byte key is acceptable:
MASTER_KMS_KEY_B64=changeme-base64-32-bytes

# ─── Database / Cache ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://oracle:oracle@db:5432/oracle
REDIS_URL=redis://redis:6379/0

# ─── LLM provider ──────────────────────────────────────────────────────
# Options: ollama | openai | none
LLM_PROVIDER=ollama

# Ollama (default). For LOCAL Ollama:
#   OLLAMA_HOST=http://localhost:11434
#   OLLAMA_MODEL=llama3.1   (or any model you've pulled: `ollama pull <model>`)
#
# For Ollama CLOUD (lets you run :cloud-tagged models like glm-5.1:cloud
# without a local GPU — see https://ollama.com):
#   OLLAMA_HOST=https://ollama.com
#   OLLAMA_API_KEY=<your ollama cloud key>
#   OLLAMA_MODEL=glm-5.1:cloud
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=glm-5.1:cloud
OLLAMA_API_KEY=
OLLAMA_KEEP_ALIVE=5m
OLLAMA_TIMEOUT=30

# OpenAI (only used if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ─── Polymarket ────────────────────────────────────────────────────────
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137

# ─── Trading safety ────────────────────────────────────────────────────
LIVE_TRADING=false
GLOBAL_MAX_DAILY_USDC=100
MIN_EDGE=0.04
