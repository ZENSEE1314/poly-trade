# ─── App ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ─── Security ──────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-64+-random-bytes
JWT_ALG=HS256
JWT_TTL_MIN=60
# Master encryption key used to wrap per-user DEKs (envelope encryption).
# In production this MUST come from a real KMS (AWS KMS / GCP KMS / Vault).
# For local dev only, a base64-encoded 32-byte key is acceptable:
MASTER_KMS_KEY_B64=changeme-base64-32-bytes

# ─── Database / Cache ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://oracle:oracle@db:5432/oracle
REDIS_URL=redis://redis:6379/0

# ─── LLM (for the MiroFish-style agent swarm) ──────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: set to use any OpenAI-compatible endpoint (e.g. local vLLM)
OPENAI_BASE_URL=

# ─── Polymarket ────────────────────────────────────────────────────────
# CLOB API host (mainnet)
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137

# ─── Trading safety ────────────────────────────────────────────────────
# Global kill switch. If false, the system NEVER submits real orders,
# regardless of per-user settings. Default: false.
LIVE_TRADING=false
# Hard ceiling per user per 24h (in USDC), enforced server-side.
GLOBAL_MAX_DAILY_USDC=100
# Refuse to trade if the model's confidence margin is below this.
MIN_EDGE=0.04
